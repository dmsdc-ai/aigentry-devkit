# aigentry.yml — 표준 설정 스키마
# 위치: 프로젝트 루트 또는 ~/.config/aigentry/aigentry.yml
# 용도: 모든 aigentry 모듈이 참조하는 통합 설정

version: 1

# 설치 프로파일
profile: core  # core | autoresearch-public | curator-public | ecosystem-full

# 모듈 설정
modules:
  telepty:
    enabled: true
    base_url: "http://localhost:3848"
    # daemon_auto_start: true

  deliberation:
    enabled: true
    runtime_path: "~/.local/lib/mcp-deliberation"
    # default_speakers: ["claude", "codex", "gemini"]
    # max_rounds: 5

  brain:
    enabled: false
    # install_mode: local  # local | sync
    # profile_root: "~/.aigentry"
    # remote_url: ""
    # project_id: ""

  dustcraw:
    enabled: false
    # preset: tech-business  # tech-business | humanities | finance | creator | custom
    # enable_service: false

  registry:
    enabled: false
    # mode: skip  # cloud | self_hosted | skip
    # api_url: ""
    # api_key: ""

  amplify:
    enabled: false
    # channels: [blog, twitter, discord, hn, geeknews]  # enabled channels
    # blog_output_dir: "~/aigentry-blog/src/content"
    # preset: devtool  # devtool | saas | open-source | creator

# 권한 (Warp allowlist/denylist 패턴)
permissions:
  allowlist: []
    # - "git status"
    # - "npm test"
    # - "telepty --version"
  denylist:
    - "rm -rf /"
    - "git push --force"
    # denylist는 항상 allowlist보다 우선

# MCP 프로파일 (Docker MCP Toolkit 패턴)
mcp_profiles:
  default:
    servers: ["deliberation"]
  research:
    servers: ["deliberation", "context7"]
  fullstack:
    servers: ["deliberation", "context7", "playwright"]

# auto-multi-llm-review 설정
auto_review:
  enabled: true
  min_speakers: 2
  max_rounds: 3
  speakers: ["claude", "codex", "gemini"]

# 검증 티어 (oh-my-claudecode Verification Tier 패턴)
verification:
  auto_tier: true  # 변경 범위에 따라 LIGHT/STANDARD/THOROUGH 자동 선택
  security_patterns:
    - "auth/"
    - "oauth"
    - ".env"
    - ".pem"
  architecture_patterns:
    - "config.ts"
    - "schema.prisma"
    - "types.ts"
    - "package.json"

# 워크스페이스 설정 (aigentry start 에서 사용)
workspace:
  root: ~/projects
  ai_cli: claude
  auto_permissions: false  # true → --dangerously-skip-permissions 자동 추가
  orchestrator: aigentry-orchestrator  # 오케스트레이터 세션 (첫 번째로 시작)
  sessions:
    - aigentry-orchestrator
    - aigentry-amplify
    - aigentry-brain
    - aigentry-deliberation
    - aigentry-telepty
    - aigentry-devkit
    - aigentry-dustcraw
    - aigentry-registry
