      "cli_flags": "--permission-mode bypassPermissions"
    },
    "analyst": {
      "path": "/path/to/your/analytics-project",
      "cli": "claude",
      "cli_flags": "--permission-mode bypassPermissions"
    }
  },
  "defaults": {
    "cli": "claude",
    "cli_flags": "--permission-mode bypassPermissions"
  }
